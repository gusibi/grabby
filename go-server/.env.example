# MCP Go Server Configuration
# Copy this file to .env and modify as needed.

HOST=0.0.0.0
PORT=5040

# Default browser name for routing requests.
# Leave empty to use the first connected browser.
# When set, requests without an explicit browser parameter will route to this browser.
DEFAULT_BROWSER=
DEBUG=false
WEBSOCKET_TIMEOUT=5.0
API_EXTRACT_TIMEOUT=60.0
