{
  "manifest_version": 3,
  "name": "Grabby - 网页内容采集助手",
  "version": "1.2.0",
  "description": "Grabby 浏览器扩展 — 通过真实浏览器抓取网页内容并转换为 Markdown",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ]
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "offscreen",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>" 
  ]
}