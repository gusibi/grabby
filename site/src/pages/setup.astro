---
import BaseLayout from '../layouts/BaseLayout.astro';

function hlJson(json: string) {
  return json.replace(
    /("(?:[^"\\]|\\.)*")\s*:/g,
    '<span class="text-[#7ee787]">$1</span>:'
  ).replace(
    /:\s*("(?:[^"\\]|\\.)*")/g,
    ': <span class="text-[#a5d6ff]">$1</span>'
  ).replace(
    /:\s*(true|false)/g,
    ': <span class="text-[#ff7b72]">$1</span>'
  ).replace(
    /:\s*(\d+)/g,
    ': <span class="text-[#79c0ff]">$1</span>'
  );
}

function hlShell(cmd: string) {
  return cmd.replace(
    /^(#.*)$/gm,
    '<span class="text-[#8b949e]">$1</span>'
  ).replace(
    /("(?:[^"\\]|\\.)*")/g,
    '<span class="text-[#a5d6ff]">$1</span>'
  ).replace(
    /('(?:[^'\\]|\\.)*')/g,
    '<span class="text-[#a5d6ff]">$1</span>'
  );
}

const healthRaw = `curl http://localhost:5040/api/health

# 预期响应
{"status":"ok","browser_connected":true,"timestamp":"..."}`;
const healthResp = hlShell(healthRaw.replace(
  /\{.*\}/s, (m) => hlJson(m)
));

const extractRaw = `curl -X POST http://localhost:5040/api/extract \\
  -H "Content-Type: application/json" \\
  -d '{"url": "https://example.com"}'

# 预期响应
{"success":true,"url":"https://example.com","title":"Example Domain","markdown":"# Example Domain\\n\\n..."}`;
const extractResp = hlShell(extractRaw.replace(
  /\{"success".*\}/s, (m) => hlJson(m)
)).replace(
  /\{"status".*\}/s, (m) => hlJson(m)
);

const claudeConfig = hlJson(`{
  "mcpServers": {
    "grabby": {
      "url": "http://localhost:5040/mcp/sse"
    }
  }
}`);

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Grabby Setup Guide",
  "description": "Complete installation and configuration guide for Grabby — Chrome extension, backend server, and MCP integration.",
  "author": { "@type": "Person", "name": "gusibi" }
});
---

<BaseLayout page="setup">
  <main class="pt-32 pb-24">
    <div class="max-w-3xl mx-auto px-8">
      <!-- Header -->
      <div class="mb-16 fade-in">
        <span class="inline-block font-mono text-xs uppercase tracking-[0.15em] text-accent mb-4 px-3 py-1.5 bg-accent/10 rounded">Setup Guide</span>
        <h1 class="font-mono font-semibold text-4xl sm:text-5xl mb-4" data-i18n="setup.title">使用指南</h1>
        <p class="text-lg text-mute dark:text-[#888]" data-i18n="setup.subtitle">从安装到运行，完整的 Grabby 配置流程。</p>
      </div>

      <!-- Quick Start -->
      <section class="fade-in mb-20">
        <h2 class="font-mono font-semibold text-2xl mb-4" data-i18n="setup.prerequisites">前置要求</h2>
        <div class="p-6 rounded-2xl bg-white dark:bg-[#161616] border border-bord dark:border-[#222]">
          <ul class="space-y-3 text-mute dark:text-[#888]">
            <li class="flex items-start gap-3">
              <span class="text-accent mt-0.5">-</span>
              <span data-i18n="setup.reqChrome"><strong class="text-[#1a1a1a] dark:text-[#e0e0e0]">Chrome 浏览器</strong>（或基于 Chromium 的浏览器）</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-0.5">-</span>
              <span data-i18n="setup.reqNode"><strong class="text-[#1a1a1a] dark:text-[#e0e0e0]">Node.js</strong> — 用于构建浏览器扩展</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-accent mt-0.5">-</span>
              <span data-i18n="setup.reqPython"><strong class="text-[#1a1a1a] dark:text-[#e0e0e0]">Python 3.13+</strong> 或 <strong class="text-[#1a1a1a] dark:text-[#e0e0e0]">Go 1.23+</strong> — 后端运行环境（二选一）</span>
            </li>
          </ul>
        </div>
      </section>

      <!-- Step 1: Clone -->
      <section class="fade-in mb-20">
        <h2 class="font-mono font-semibold text-2xl mb-4" data-i18n="setup.step1">1. 克隆项目</h2>
        <pre><code set:html={hlShell(`git clone https://github.com/gusibi/grabby.git\ncd grabby`)} /></pre>
      </section>

      <!-- Step 2: Chrome Extension -->
      <section class="fade-in mb-20">
        <h2 class="font-mono font-semibold text-2xl mb-4" data-i18n="setup.step2">2. 安装浏览器扩展</h2>

        <div class="space-y-6">
          <div class="p-6 rounded-2xl bg-white dark:bg-[#161616] border border-bord dark:border-[#222]">
            <h3 class="font-mono font-semibold text-lg mb-3" data-i18n="setup.method1">方式一：Chrome 网上应用店（推荐）</h3>
            <p class="text-mute dark:text-[#888] mb-4" data-i18n="setup.method1Desc">一键安装，自动更新。</p>
            <a
              href="https://chromewebstore.google.com/detail/mcp-%E7%BD%91%E9%A1%B5%E5%86%85%E5%AE%B9%E9%87%87%E9%9B%86%E5%B7%A5%E5%85%B7/hfimnafeekedoeeflppddlkbhcbbnfab"
              class="inline-flex items-center gap-2 px-5 py-2.5 bg-accent text-white rounded-lg font-mono text-sm font-semibold hover:bg-accent-hover transition-all"
              target="_blank" rel="noopener"
              data-i18n="setup.installExt"
            >
              安装 Grabby 扩展
            </a>
          </div>

          <div class="p-6 rounded-2xl bg-white dark:bg-[#161616] border border-bord dark:border-[#222]">
            <h3 class="font-mono font-semibold text-lg mb-3" data-i18n="setup.method2">方式二：开发模式加载</h3>
            <p class="text-mute dark:text-[#888] mb-3" data-i18n="setup.method2Desc">如果你需要修改源码或进行开发调试：</p>
            <ol class="list-decimal list-inside space-y-2 text-mute dark:text-[#888]">
              <li data-i18n="setup.dev1">打开 Chrome，访问 <code>chrome://extensions</code></li>
              <li>开启右上角 <strong class="text-[#1a1a1a] dark:text-[#e0e0e0]" data-i18n="setup.dev2">"开发者模式"</strong></li>
              <li>点击 <strong class="text-[#1a1a1a] dark:text-[#e0e0e0]" data-i18n="setup.dev3">"加载已解压的扩展程序"</strong></li>
              <li data-i18n="setup.dev4">选择项目中的 <code>chrome-extension/</code> 目录</li>
            </ol>
          </div>
        </div>
      </section>

      <!-- Step 3: Backend Server -->
      <section class="fade-in mb-20">
        <h2 class="font-mono font-semibold text-2xl mb-4" data-i18n="setup.step3">3. 安装后端服务</h2>

        <div class="space-y-6">
          <!-- Python -->
          <div class="p-6 rounded-2xl bg-white dark:bg-[#161616] border border-bord dark:border-[#222]">
            <h3 class="font-mono font-semibold text-lg mb-3" data-i18n="setup.pythonTitle">Python 后端（推荐新手）</h3>
            <p class="text-mute dark:text-[#888] mb-4" data-i18n="setup.pythonDesc">使用 uv 包管理器一键运行，自动处理虚拟环境和依赖安装：</p>

            <h4 class="font-mono font-semibold text-sm mb-2 text-accent">1) 安装 uv（如未安装）</h4>
            <pre><code set:html={hlShell(`curl -LsSf https://astral.sh/uv/install.sh | sh`)} /></pre>

            <h4 class="font-mono font-semibold text-sm mb-2 mt-5 text-accent">2) 配置环境变量</h4>
            <pre><code set:html={hlShell(`cd python-server\ncp .env.example .env`)} /></pre>
            <p class="text-sm text-mute dark:text-[#888] mt-3 mb-2">编辑 <code>.env</code> 文件，按需修改以下配置：</p>
            <div class="overflow-x-auto">
              <table class="w-full text-sm text-left text-mute dark:text-[#888] border-collapse">
                <thead>
                  <tr class="border-b border-bord dark:border-[#333]">
                    <th class="py-2 pr-4 font-mono font-semibold text-[#1a1a1a] dark:text-[#e0e0e0]">配置项</th>
                    <th class="py-2 pr-4 font-mono font-semibold text-[#1a1a1a] dark:text-[#e0e0e0]">默认值</th>
                    <th class="py-2 font-mono font-semibold text-[#1a1a1a] dark:text-[#e0e0e0]">说明</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="border-b border-bord dark:border-[#222]">
                    <td class="py-2 pr-4 font-mono">HOST</td>
                    <td class="py-2 pr-4 font-mono">0.0.0.0</td>
                    <td class="py-2">服务器监听地址</td>
                  </tr>
                  <tr class="border-b border-bord dark:border-[#222]">
                    <td class="py-2 pr-4 font-mono">PORT</td>
                    <td class="py-2 pr-4 font-mono">5040</td>
                    <td class="py-2">服务器监听端口</td>
                  </tr>
                  <tr class="border-b border-bord dark:border-[#222]">
                    <td class="py-2 pr-4 font-mono">CONNECT_ID</td>
                    <td class="py-2 pr-4 font-mono">browser-tools</td>
                    <td class="py-2">浏览器扩展连接 ID，<strong>两端必须一致</strong></td>
                  </tr>
                  <tr class="border-b border-bord dark:border-[#222]">
                    <td class="py-2 pr-4 font-mono">API_KEY</td>
                    <td class="py-2 pr-4 font-mono">（空）</td>
                    <td class="py-2">HTTP/WebSocket 端点保护密钥，留空表示关闭校验</td>
                  </tr>
                  <tr class="border-b border-bord dark:border-[#222]">
                    <td class="py-2 pr-4 font-mono">DEBUG</td>
                    <td class="py-2 pr-4 font-mono">false</td>
                    <td class="py-2">调试模式，开启后输出更多日志</td>
                  </tr>
                  <tr class="border-b border-bord dark:border-[#222]">
                    <td class="py-2 pr-4 font-mono">WEBSOCKET_TIMEOUT</td>
                    <td class="py-2 pr-4 font-mono">5.0</td>
                    <td class="py-2">WebSocket 请求超时（秒）</td>
                  </tr>
                  <tr class="border-b border-bord dark:border-[#222]">
                    <td class="py-2 pr-4 font-mono">API_EXTRACT_TIMEOUT</td>
                    <td class="py-2 pr-4 font-mono">60.0</td>
                    <td class="py-2">HTTP API extract 端点超时（秒）</td>
                  </tr>
                  <tr>
                    <td class="py-2 pr-4 font-mono">DEFAULT_BROWSER</td>
                    <td class="py-2 pr-4 font-mono">（空）</td>
                    <td class="py-2">默认浏览器名称，留空使用第一个连接的浏览器</td>
                  </tr>
                </tbody>
              </table>
            </div>
            <p class="text-xs text-mute dark:text-[#666] mt-3">配置优先级：系统环境变量 &gt; .env 文件 &gt; 代码默认值</p>

            <h4 class="font-mono font-semibold text-sm mb-2 mt-5 text-accent">3) 启动服务</h4>
            <pre><code set:html={hlShell(`# 方式一：使用 uv 直接运行（推荐）\nuv run python main.py\n\n# 方式二：使用启动脚本（自动检测 Python/Go 后端）\ncd ..\n./start.sh`)} /></pre>
            <p class="text-sm text-mute dark:text-[#888] mt-3 mb-2">服务启动后，控制台会输出可用端点：</p>
            <pre><code set:html={hlShell(`HTTP API:\n  POST http://localhost:5040/api/extract    - 提取网页 Markdown\n  GET  http://localhost:5040/api/health     - 健康检查\n  GET  http://localhost:5040/api/browsers   - 已连接浏览器列表\n\nWebSocket:\n  ws://localhost:5040/ws_browser  - 浏览器扩展连接\n\nMCP Server:\n  http://localhost:5040/mcp/sse`)} /></pre>
          </div>

          <!-- Go -->
          <div class="p-6 rounded-2xl bg-white dark:bg-[#161616] border border-bord dark:border-[#222]">
            <h3 class="font-mono font-semibold text-lg mb-3" data-i18n="setup.goTitle">Go 后端（推荐资源受限环境）</h3>
            <pre><code set:html={hlShell(`cd go-server\ncp .env.example .env\n# 编辑 .env 按需修改配置（配置项与 Python 后端一致）\n\ngo build -o go-server .\n./go-server`)} /></pre>
            <p class="text-sm text-mute dark:text-[#888] mt-3">Go 后端支持交叉编译：</p>
            <pre><code set:html={hlShell(`# macOS ARM64\nGOOS=darwin GOARCH=arm64 go build -o go-server-darwin .\n\n# Linux AMD64\nGOOS=linux GOARCH=amd64 go build -o go-server-linux .\n\n# Windows\nGOOS=windows GOARCH=amd64 go build -o go-server.exe .`)} /></pre>
          </div>
        </div>
      </section>

      <!-- Step 4: Configuration -->
      <section class="fade-in mb-20">
        <h2 class="font-mono font-semibold text-2xl mb-4" data-i18n="setup.step4">4. 配置扩展</h2>
        <div class="space-y-6">
          <div class="p-6 rounded-2xl bg-white dark:bg-[#161616] border border-bord dark:border-[#222]">
            <h3 class="font-mono font-semibold text-sm mb-3 text-accent">打开设置页面</h3>
            <p class="text-mute dark:text-[#888] mb-3">右键点击 Chrome 工具栏中的 <strong class="text-[#1a1a1a] dark:text-[#e0e0e0]">Grabby 图标</strong> → <strong class="text-[#1a1a1a] dark:text-[#e0e0e0]">选项 / Options</strong></p>

            <h3 class="font-mono font-semibold text-sm mb-3 mt-5 text-accent">填写连接信息</h3>
            <div class="overflow-x-auto">
              <table class="w-full text-sm text-left text-mute dark:text-[#888] border-collapse">
                <thead>
                  <tr class="border-b border-bord dark:border-[#333]">
                    <th class="py-2 pr-4 font-mono font-semibold text-[#1a1a1a] dark:text-[#e0e0e0]">字段</th>
                    <th class="py-2 pr-4 font-mono font-semibold text-[#1a1a1a] dark:text-[#e0e0e0]">示例值</th>
                    <th class="py-2 font-mono font-semibold text-[#1a1a1a] dark:text-[#e0e0e0]">说明</th>
                  </tr>
                </thead>
                <tbody>
                  <tr class="border-b border-bord dark:border-[#222]">
                    <td class="py-2 pr-4 font-mono">WebSocket 服务器地址</td>
                    <td class="py-2 pr-4 font-mono text-xs">ws://localhost:5040/ws_browser</td>
                    <td class="py-2">后端 WebSocket 端点，与服务端 <code>HOST</code>:<code>PORT</code> 对应</td>
                  </tr>
                  <tr class="border-b border-bord dark:border-[#222]">
                    <td class="py-2 pr-4 font-mono">API 密钥</td>
                    <td class="py-2 pr-4 font-mono">browser-tools</td>
                    <td class="py-2">必须与服务端 <code>.env</code> 中的 <code>CONNECT_ID</code> 一致</td>
                  </tr>
                  <tr class="border-b border-bord dark:border-[#222]">
                    <td class="py-2 pr-4 font-mono">浏览器名称</td>
                    <td class="py-2 pr-4 font-mono">chrome-office</td>
                    <td class="py-2">多浏览器场景下的标识名称（可选，单浏览器留空）</td>
                  </tr>
                  <tr>
                    <td class="py-2 pr-4 font-mono">启动时自动连接</td>
                    <td class="py-2 pr-4 font-mono">勾选</td>
                    <td class="py-2">推荐开启，Chrome 启动后自动连接后端服务</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <h3 class="font-mono font-semibold text-sm mb-3 mt-5 text-accent">认证原理</h3>
            <p class="text-mute dark:text-[#888] mb-3">扩展连接时，会将 <strong class="text-[#1a1a1a] dark:text-[#e0e0e0]">API 密钥</strong> 作为 <code>conn_id</code> 参数附加到 WebSocket URL：</p>
            <pre><code set:html={hlShell(`ws://localhost:5040/ws_browser?conn_id=browser-tools`)} /></pre>
            <p class="text-mute dark:text-[#888] mt-3 text-sm">服务端验证 <code>conn_id</code> 是否与 <code>.env</code> 中的 <code>CONNECT_ID</code> 匹配。不一致则拒绝连接（返回 403）。因此<strong>扩展的 API 密钥必须与服务端的 CONNECT_ID 保持一致</strong>。</p>

            <h3 class="font-mono font-semibold text-sm mb-3 mt-5 text-accent">保存并连接</h3>
            <ol class="list-decimal list-inside space-y-2 text-mute dark:text-[#888]">
              <li>填写上述字段</li>
              <li>点击页面底部的 <strong class="text-[#1a1a1a] dark:text-[#e0e0e0]">保存设置</strong></li>
              <li>扩展自动尝试连接后端服务</li>
              <li>看到 <strong class="text-[#059669]">"连接状态：已连接"</strong> 即表示成功</li>
            </ol>
          </div>
        </div>
      </section>

      <!-- Step 5: Verify -->
      <section class="fade-in mb-20">
        <h2 class="font-mono font-semibold text-2xl mb-4" data-i18n="setup.step5">5. 验证安装</h2>
        <div class="space-y-4">
          <div class="p-6 rounded-2xl bg-white dark:bg-[#161616] border border-bord dark:border-[#222]">
            <h3 class="font-mono font-semibold text-sm mb-3 text-accent" data-i18n="setup.health">健康检查</h3>
            <pre><code set:html={healthResp} /></pre>
          </div>

          <div class="p-6 rounded-2xl bg-white dark:bg-[#161616] border border-bord dark:border-[#222]">
            <h3 class="font-mono font-semibold text-sm mb-3 text-accent" data-i18n="setup.testExtract">测试提取</h3>
            <pre><code set:html={extractResp} /></pre>
          </div>
        </div>
      </section>

      <!-- MCP Config -->
      <section class="fade-in mb-20">
        <h2 class="font-mono font-semibold text-2xl mb-4" data-i18n="setup.step6">6. 配置 Claude Desktop</h2>
        <p class="text-mute dark:text-[#888] mb-4" data-i18n="setup.claudeDesc">在 Claude Desktop 的配置文件中添加 Grabby MCP Server：</p>
        <div class="p-6 rounded-2xl bg-white dark:bg-[#161616] border border-bord dark:border-[#222]">
          <pre><code set:html={claudeConfig} /></pre>
        </div>
        <p class="text-sm text-mute dark:text-[#888] mt-3" data-i18n="setup.claudeNote">
          配置文件位置：<code>~/Library/Application Support/Claude/claude_desktop_config.json</code> (macOS)
        </p>
      </section>

      <!-- Troubleshooting -->
      <section class="fade-in">
        <h2 class="font-mono font-semibold text-2xl mb-4" data-i18n="setup.troubleshoot">常见问题</h2>
        <div class="space-y-4">
          <div class="p-6 rounded-2xl bg-white dark:bg-[#161616] border border-bord dark:border-[#222]">
            <h3 class="font-mono font-semibold mb-2" data-i18n="setup.ts1Title">扩展无法连接服务器</h3>
            <ol class="list-decimal list-inside space-y-1 text-mute dark:text-[#888] text-sm">
              <li data-i18n="setup.ts1">确认后端服务已启动</li>
              <li data-i18n="setup.ts2">检查 WebSocket 地址和端口是否正确</li>
              <li data-i18n="setup.ts3">确认 API 密钥与服务器 <code>.env</code> 中的配置一致</li>
              <li data-i18n="setup.ts4">检查防火墙是否放行端口</li>
            </ol>
          </div>
          <div class="p-6 rounded-2xl bg-white dark:bg-[#161616] border border-bord dark:border-[#222]">
            <h3 class="font-mono font-semibold mb-2" data-i18n="setup.ts2Title">Python 依赖安装失败</h3>
            <p class="text-mute dark:text-[#888] text-sm" data-i18n="setup.ts2Desc">推荐使用 <code>uv</code> 替代 <code>pip</code>，uv 会自动创建虚拟环境并解析依赖。</p>
          </div>
          <div class="p-6 rounded-2xl bg-white dark:bg-[#161616] border border-bord dark:border-[#222]">
            <h3 class="font-mono font-semibold mb-2" data-i18n="setup.ts3Title">Go 编译失败</h3>
            <p class="text-mute dark:text-[#888] text-sm" data-i18n="setup.ts3Desc">确保 Go 版本 &gt;= 1.23。如果模块下载失败，设置代理：<code>go env -w GOPROXY=https://goproxy.cn,direct</code></p>
          </div>
        </div>
      </section>
    </div>
  </main>

  <script type="application/ld+json" set:html={jsonLd} />
</BaseLayout>
