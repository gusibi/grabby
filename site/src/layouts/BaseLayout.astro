  function detectLang() {
    try {
      const stored = localStorage.getItem('grabby-lang');
      if (stored && I18N[stored]) return stored;
      const bl = navigator.language || '';
      if (bl.startsWith('zh')) return 'zh-CN';
      if (bl.startsWith('en')) return 'en';
    } catch (e) {}
    return 'zh-CN';
  }

  let currentLang = detectLang();

  function t(path: string) {
    const keys = path.split('.');
    let val: any = I18N[currentLang];
    for (const k of keys) {
      if (val == null) return path;
      val = val[k];
    }
    return val != null && typeof val === 'string' ? val : path;
  }

  function applyTranslations() {
    document.documentElement.lang = currentLang;
    document.querySelectorAll('[data-i18n]').forEach(el => {
      const text = t(el.getAttribute('data-i18n') || '');
      if (text && typeof text === 'string') el.textContent = text;
    });
    document.querySelectorAll('[data-i18n-placeholder]').forEach(el => {
      const text = t(el.getAttribute('data-i18n-placeholder') || '');
      if (text && typeof text === 'string') el.setAttribute('placeholder', text);
    });

    const desc = document.querySelector('meta[name="description"]');
    const pageType = document.body.getAttribute('data-page') || 'home';
    const titleMap: Record<string, Record<string, string>> = {
      home: { 'zh-CN': 'Grabby — URL 转 Markdown，真实浏览器驱动 | 网页内容采集', en: 'Grabby — URL to Markdown, powered by real browser | Web Content Capture' },
      setup: { 'zh-CN': 'Grabby 使用指南 — 安装与配置', en: 'Grabby Setup Guide — Installation & Configuration' },
      api: { 'zh-CN': 'Grabby API 参考 — HTTP、MCP 与 WebSocket', en: 'Grabby API Reference — HTTP, MCP & WebSocket' },
    };
    if (titleMap[pageType]?.[currentLang]) document.title = titleMap[pageType][currentLang];

    const switchBtn = document.querySelector('.lang-switch');
    if (switchBtn) {
      switchBtn.textContent = t('langLabel');
      switchBtn.setAttribute('aria-label', t('langSwitch'));
    }

    try { localStorage.setItem('grabby-lang', currentLang); } catch (e) {}
  }

  function switchLang() {
    currentLang = currentLang === 'zh-CN' ? 'en' : 'zh-CN';
    applyTranslations();
  }

  // --- Theme ---
  function getTheme() {
    try {
      const stored = localStorage.getItem('grabby-theme');
      if (stored === 'light' || stored === 'dark') return stored;
    } catch (e) {}
    if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) return 'light';
    return 'dark';
  }

  function applyTheme(theme: string) {
    if (theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    try { localStorage.setItem('grabby-theme', theme); } catch (e) {}
  }

  function toggleTheme() {
    const isDark = document.documentElement.classList.contains('dark');
    applyTheme(isDark ? 'light' : 'dark');
  }

  function init() {
    applyTheme(getTheme());
    if (window.matchMedia) {
      window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
        if (!localStorage.getItem('grabby-theme')) {
          applyTheme(e.matches ? 'dark' : 'light');
        }
      });
    }

    applyTranslations();

    const langBtn = document.querySelector('.lang-switch');
    if (langBtn) langBtn.addEventListener('click', switchLang);

    const themeBtn = document.querySelector('.theme-toggle');
    if (themeBtn) themeBtn.addEventListener('click', toggleTheme);

    const toggle = document.querySelector('.nav-toggle');
    const links = document.querySelector('.nav-links');
    if (toggle && links) {
      toggle.addEventListener('click', () => {
        const open = links.classList.toggle('!flex');
        toggle.setAttribute('aria-expanded', String(open));
      });
      links.addEventListener('click', (e) => {
        if ((e.target as Element).tagName === 'A') {
          links.classList.remove('!flex');
          toggle.setAttribute('aria-expanded', 'false');
        }
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
    );
    document.querySelectorAll('.fade-in').forEach(el => observer.observe(el));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
